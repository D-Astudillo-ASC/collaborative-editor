PORT=5000
# Comma-separated list of allowed CORS origins.
# Production (Fly.io): set via `fly secrets set FRONTEND_URL=https://yourapp.vercel.app`
# Local dev: http://localhost:3000
# Multiple: https://yourapp.vercel.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Neon / Postgres (required)
# For local development with Docker: postgres://postgres:postgres@localhost:5432/collaborative_editor?sslmode=disable
# For Neon production: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
PG_POOL_MAX=10
# Set to 'disable' for local Postgres (no SSL needed)
PGSSLMODE=require

# Clerk (required once auth is wired)
# Example: https://<your-clerk-domain>/.well-known/jwks.json
CLERK_JWKS_URL=
# Optional hardening
CLERK_ISSUER=
CLERK_AUDIENCE=
# Backend API (share dialog: search users like Google Docs). Same Clerk app — Dashboard → API keys → Secret key.
# Without this, people search falls back to Postgres (only users who have signed in at least once).
CLERK_SECRET_KEY=

# R2 (required once snapshots are wired)
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Snapshotting knobs
SNAPSHOT_EVERY_N_UPDATES=50
SNAPSHOT_EVERY_MS=30000
PRUNE_UPDATES_BEFORE_SNAPSHOT=false

# Redis (required for execution queue and rate limiting)
# For local development: redis://localhost:6379
# For Upstash (free tier): redis://default:password@host:port
REDIS_URL=redis://localhost:6379

# Docker sandboxing for code execution (default: true)
# Set to false to use child_process instead (less secure, for local dev only)
# CRITICAL: Always use Docker (true) in production for security
USE_DOCKER=true

# Docker executor image names (optional - defaults to local images)
# For Fly.io production: registry.fly.io/your-app-name:python-executor
# For local development: python-executor:latest (default)
PYTHON_EXECUTOR_IMAGE=python-executor:latest
JAVA_EXECUTOR_IMAGE=java-executor:latest

# Phase 8: AI Assistant (required for /api/ai/chat)
# Get a free API key at https://aistudio.google.com
# The server uses Google Gemini via the OpenAI-compatible endpoint.
GOOGLE_AI_API_KEY=

